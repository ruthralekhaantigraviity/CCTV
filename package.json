{
    "name": "task-cctv-root",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "client",
        "server"
    ],
    "scripts": {
        "install-all": "npm install",
        "client": "npm run dev --workspace=client",
        "server": "npm run dev --workspace=server",
        "dev": "node dev.js",
        "build": "npm run build --workspace=client",
        "lint": "npm run lint --workspace=client",
        "seed": "npm run seed --workspace=server"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}